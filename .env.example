# =============================================================================
# Multi-Agent AI Platform — Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
APP_NAME="Multi-Agent AI Platform"
APP_VERSION=1.0.0
SECRET_KEY=change-me-to-a-secure-random-string-32-chars
DEBUG=true
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","null"]
# "null" permite que frontend/index.html abra desde file:// en el navegador

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=multiagent_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=multiagent_db
# Constructed automatically from above — do not edit unless needed
DATABASE_URL=postgresql+asyncpg://multiagent_user:your_postgres_password@localhost:5432/multiagent_db

# ── Amazon Bedrock ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
# Default model for all agents (can be overridden per agent in DB)
BEDROCK_DEFAULT_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# Model used by the orchestrator for routing decisions
BEDROCK_ORCHESTRATOR_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.1

# ── Amazon S3 ─────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=multiagent-documents
S3_REGION=us-east-1
S3_PREFIX=uploads/
# Leave empty to use the same AWS credentials above
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ── Google Gemini Embedding 2 ─────────────────────────────────────────────────
# Path to your Google service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Alternativa: usar API KEY directa en lugar de service account
# GOOGLE_API_KEY=your_gemini_api_key
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Model name — DO NOT CHANGE unless switching embedding provider
GOOGLE_EMBEDDING_MODEL=gemini-embedding-2-preview
# gemini-embedding-2-preview outputs 3072 dims by default (MRL supports lower dimensions)
# Ensure your Pinecone index dimension matches this value
EMBEDDING_DIMENSION=3072

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=multiagent-knowledge
PINECONE_ENVIRONMENT=us-east-1-aws    # or gcp-starter, etc.
PINECONE_CLOUD=aws                    # aws | gcp
PINECONE_REGION=us-east-1

# ── Document Processing ───────────────────────────────────────────────────────
CHUNK_SIZE=3072                      # characters per chunk
CHUNK_OVERLAP=200                     # overlap between chunks
MAX_FILE_SIZE_MB=50                   # max upload size in MB
ALLOWED_EXTENSIONS=["pdf","docx","txt","md"]
# OCR (requires Tesseract installed on system)
OCR_ENABLED=false
OCR_LANGUAGE=spa                      # spa=Spanish, eng=English

# ── Multi-Tenancy ─────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=1                   # Default tenant for single-tenant mode

# ── Background Tasks ──────────────────────────────────────────────────────────
# For production, replace with Celery + Redis
BACKGROUND_WORKER=fastapi             # fastapi (BackgroundTasks) | celery
REDIS_URL=redis://localhost:6379/0    # Used only if BACKGROUND_WORKER=celery

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=                          # Optional: leave empty to disable
ENABLE_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
